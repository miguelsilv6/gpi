# ─── PORTO LOCAL ──────────────────────────────────────────────────────────────
# Porto onde a app fica disponível em http://localhost:HOST_PORT
HOST_PORT=3000

# ─── BASE DE DADOS ────────────────────────────────────────────────────────────
# Em Docker, deixa estas como estão. O DATABASE_URL é construído pelo compose.
POSTGRES_USER=gpi_user
POSTGRES_PASSWORD=__GERAR_NO_INSTALL__
POSTGRES_DB=gpi_db

# Para correr a app FORA do Docker, descomenta e ajusta:
# DATABASE_URL="postgresql://gpi_user:PASSWORD@localhost:5432/gpi_db?schema=public"

# ─── AUTENTICAÇÃO (NextAuth) ──────────────────────────────────────────────────
# Gerar com: openssl rand -base64 32  (Linux/Mac)
#         ou: [Convert]::ToBase64String((1..32 | %{ Get-Random -Max 256 }))  (PowerShell)
NEXTAUTH_SECRET=__GERAR_NO_INSTALL__
NEXTAUTH_URL=http://localhost:3000

# Password inicial do admin@gpi.pt criado pelo seed
SEED_PASSWORD=Admin123!

# ─── CRON ─────────────────────────────────────────────────────────────────────
CRON_SECRET=__GERAR_NO_INSTALL__

# ─── BACKUPS (OPCIONAL) ───────────────────────────────────────────────────────
# Comando opcional executado no fim de cada backup automático. {file} é
# substituído pelo path absoluto do dump (.sql.gz). Exemplos:
#   BACKUP_REMOTE_CMD="rclone copy {file} remote:gpi-backups/"
#   BACKUP_REMOTE_CMD="scp {file} backup-server:/srv/gpi-backups/"
# Se vazio, os backups ficam só no volume local (./backups).
BACKUP_REMOTE_CMD=

# ─── ATUALIZAÇÕES (OPCIONAL) ──────────────────────────────────────────────────
# Repo de origem das releases verificadas pelo cron a cada 30 min.
# Override caso este deploy use um fork.
GITHUB_REPO=miguelsilv6/gestao-projetos
# Token GitHub opcional. Sem token o rate-limit é 60 req/h (suficiente para
# checks normais). Com token sobe para 5000 req/h. Cria um Personal Access
# Token sem scopes (read-only de releases públicas funciona sem permissões).
GITHUB_TOKEN=

# ─── PROXY REVERSO (OPCIONAL) ────────────────────────────────────────────────
# Define como 1 APENAS quando a app corre atrás de um proxy reverso (nginx,
# Caddy, etc.) configurado para remover/sobrescrever X-Forwarded-For antes de
# encaminhar pedidos. Activa rate-limiting por IP real no endpoint de login.
# Sem esta variável o header X-Forwarded-For é ignorado (não é de confiança).
TRUST_PROXY=

# ─── EMAIL (OPCIONAL) ─────────────────────────────────────────────────────────
# Estas variáveis são o FALLBACK. O servidor SMTP pode ser configurado pelo
# administrador em Configurações → Sistema (guardado na BD, palavra-passe
# cifrada); quando o host está definido na UI, sobrepõe-se a estas variáveis.
# Se ambos vazios, as notificações só aparecem na app (sem email).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=GPI Sistema
SMTP_FROM_EMAIL=noreply@gpi.local

# Chave para cifrar segredos guardados na BD (ex: palavra-passe SMTP definida
# na UI). Opcional — se vazia, é usado o NEXTAUTH_SECRET. Se a definires,
# mantém-na estável: alterá-la torna os segredos já cifrados indecifráveis.
SETTINGS_ENCRYPTION_KEY=

# ─── CAPTCHA (OPCIONAL) ───────────────────────────────────────────────────────
# Cloudflare Turnstile — aparece automaticamente após 3 tentativas falhadas.
# Criar site em: https://dash.cloudflare.com/?to=/:account/turnstile
# Sem estas variáveis o CAPTCHA está desativado (degradação graciosa).
NEXT_PUBLIC_CF_TURNSTILE_SITE_KEY=
CF_TURNSTILE_SECRET_KEY=
