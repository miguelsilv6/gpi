generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  INSPETOR
  INSPETOR_CHEFE
  COORDENADOR
  ESTATISTICA
  ADMINISTRACAO
}

enum TipoAusencia {
  FERIAS
  FOLGA
}

enum TipoNotificacao {
  BACKUP_FALHOU
  PRAZO_APROXIMANDO
  PRAZO_ULTRAPASSADO
  ATIVIDADE_ADICIONADA
  INQUERITO_ATRIBUIDO
  INQUERITO_TRANSFERIDO
  ATIVIDADE_PRAZO_APROXIMANDO
  ATUALIZACAO_FALHOU
  ATUALIZACAO_CONCLUIDA
  BUGREPORT_CRIADO
  CONTROLO_APROXIMANDO
  TRANSICAO_AUTOMATICA
  INTERCECAO_A_TERMINAR
  COLABORACAO_AUTORIZADA
  APREENSAO_PARADA
  PERICIA_ATRASADA
}

enum SeveridadeBug {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

enum EstadoBug {
  ABERTO
  EM_ANALISE
  RESOLVIDO
  REJEITADO
}

// Tipo de ligação entre dois inquéritos.
//   APENSO      — processos fisicamente apensados.
//   CONEXO      — conexão de processos (art. 24.º CPP).
//   RELACIONADO — relação genérica de investigação.
enum TipoRelacaoInquerito {
  RELACIONADO
  APENSO
  CONEXO
}

// Tipo de diligência/evento de agenda (datas de tribunal e atos processuais).
enum TipoDiligencia {
  JULGAMENTO
  INQUIRICAO
  BUSCA
  INTERROGATORIO
  RECONSTITUICAO
  REUNIAO
  OUTRA
}

// ── Interceções de comunicações (escutas) ────────────────────────────────────

// Tipo da linha intercetada (o que está sob escuta).
enum TipoLinhaIntercecao {
  SIM
  IMEI
  OUTRO
}

// Tipo de produto de interesse registado numa interceção.
enum TipoProdutoIntercecao {
  CHAMADA
  SMS
  MMS
  DADOS
  LOCALIZACAO
  OUTRO
}

// Direção do produto relativamente ao alvo.
enum DirecaoProdutoIntercecao {
  EFETUADA
  RECEBIDA
}

model Brigada {
  id          String   @id @default(cuid())
  nome        String   @unique
  descricao   String?
  ativa       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  utilizadores Utilizador[]
  inqueritos   Inquerito[]
  ausencias    Ausencia[]
}

model Utilizador {
  id           String   @id @default(cuid())
  nome         String
  email        String   @unique
  // Internal identification number (e.g. "número de LT"). Unique when set,
  // optional so legacy accounts and seed users don't have to backfill yet.
  lt           Int?     @unique
  telemovel    String?
  passwordHash String
  role         Role
  ativo        Boolean  @default(true)
  chefeSupremo Boolean  @default(false)
  tokenVersion Int      @default(0)
  lockedUntil  DateTime?
  failedLoginCount Int  @default(0)
  lastLoginAt  DateTime?
  lastLoginIp  String?
  // Última atividade (heartbeat): atualizado pelo poll de notificações (~90s)
  // enquanto o utilizador tem a app aberta. Base do indicador "online agora"
  // (as sessões são JWT, sem registo em BD). null = nunca visto ativo.
  lastSeenAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  brigada   Brigada? @relation(fields: [brigadaId], references: [id])
  brigadaId String?

  inqueritos           Inquerito[]   @relation("InspetorAtribuido")
  inqueritosDocPendente Inquerito[]  @relation("DocumentacaoPendentePor")
  atividadesRealizadas Atividade[]
  notificacoes         Notificacao[]
  sessoes              Sessao[]
  passwordResetTokens  PasswordResetToken[]
  atualizacoesIniciadas AtualizacaoSistema[]
  etiquetas            Etiqueta[]
  ajudasRegistos       AjudasRegisto[]
  // Per-user overrides for Ajudas Mensais calculations.
  // When set, these take precedence over the global AjudasConfig values.
  ajudasVencimentoBase Float?
  ajudasTaxaIRS        Float?
  // Estados pré-selecionados por defeito no filtro da pesquisa de inquéritos
  // (guardados como codigos, estáveis a renomeações). Quando não vazio,
  // sobrepõe-se ao default global (ConfiguracaoSistema.inqueritoFiltroEstadosDefault).
  inqueritoFiltroEstadosDefault String[] @default([])
  // Nº de inquéritos por página pré-definido na listagem. Null = usa o default
  // do sistema (20). Restrito a valores conhecidos (20/50/100/250) na validação.
  inqueritoPageSizeDefault Int?
  // Tour de boas-vindas: data em que o utilizador concluiu ou saltou a tour
  // guiada. Null = ainda não a viu → arranca automaticamente no primeiro
  // acesso. Pode ser reposta para voltar a ver ("Ver tour novamente" no Perfil).
  tourConcluidaEm      DateTime?
  viaturas             Viatura[]
  ausencias            Ausencia[]    @relation("AusenciasInspetor")
  notificacaoPreferencias NotificacaoPreferencia[]
  bugReports           BugReport[]
  controlosCriados     Controlo[]   @relation("ControloCriador")
  controloRealizacoes  ControloRealizacao[] @relation("ControloRealizacaoPor")
  documentosCarregados Documento[]  @relation("DocumentoUploader")
  notasInquerito       NotaInquerito[] @relation("NotaInqueritoAutor")
  notasEditadas        NotaInquerito[] @relation("NotaInqueritoEditor")
  tarefasInquerito     TarefaInquerito[]
  relacoesInqueritoCriadas InqueritoRelacao[] @relation("RelacaoCriador")
  diligenciasCriadas   Diligencia[]  @relation("DiligenciaCriador")
  intercecaoProdutosCriados IntercecaoProduto[] @relation("IntercecaoProdutoCriador")
  // Colaborações autorizadas: inquéritos onde este utilizador é colaborador,
  // e autorizações que este utilizador concedeu a outros.
  colaboracoes           InqueritoColaborador[] @relation("ColaboradorInquerito")
  colaboracoesConcedidas InqueritoColaborador[] @relation("ColaboradorConcedidoPor")
  apreensoesRegistadas   Apreensao[]  @relation("ApreensaoRegistador")
  periciasRegistadas     Pericia[]    @relation("PericiaRegistador")
  pushSubscriptions      PushSubscription[]
  webauthnCredentials    WebauthnCredential[]

  @@index([brigadaId])
  @@index([role])
  @@index([brigadaId, role])
}

/// Subscrição de Web Push (browser Push API). Um utilizador pode ter várias
/// (uma por dispositivo/browser). `endpoint` é único — re-subscrever o mesmo
/// browser faz upsert na mesma linha. Enviar push a um endpoint que devolva
/// 404/410 remove a linha (subscrição expirada).
model PushSubscription {
  id           String     @id @default(cuid())
  utilizador   Utilizador @relation(fields: [utilizadorId], references: [id], onDelete: Cascade)
  utilizadorId String
  endpoint     String     @unique
  p256dh       String
  auth         String
  userAgent    String?
  createdAt    DateTime   @default(now())

  @@index([utilizadorId])
}

/// Credencial WebAuthn (passkey) de um utilizador — permite iniciar sessão por
/// biometria / chave de segurança, em alternativa à password. Um utilizador
/// pode registar várias (um dispositivo/chave por linha). Guarda-se o suficiente
/// para verificar futuras asserções: id da credencial, chave pública e contador.
model WebauthnCredential {
  id           String     @id @default(cuid())
  utilizador   Utilizador @relation(fields: [utilizadorId], references: [id], onDelete: Cascade)
  utilizadorId String
  // Identificador da credencial (base64url), único globalmente.
  credentialId String     @unique
  // Chave pública COSE (base64url).
  publicKey    String
  // Contador de assinaturas — deteção de clonagem (deve ser monótono).
  counter      Int        @default(0)
  // Transportes disponíveis (ex.: "internal,hybrid"), usados como dica ao cliente.
  transports   String?
  deviceType   String?
  backedUp     Boolean    @default(false)
  // Nome amigável dado pelo utilizador (ex.: "iPhone de serviço").
  nome         String?
  createdAt    DateTime   @default(now())
  lastUsedAt   DateTime?

  @@index([utilizadorId])
}

model Inquerito {
  id             String   @id @default(cuid())
  nuipc          String   @unique
  nai            String?  @unique
  // Free-text natureza, kept for transitional backfill. Once `crimeId` is
  // populated for every row (via scripts/migrate-natureza-to-crime.ts) and
  // the UI no longer reads from this field, a future migration drops it.
  natureza       String
  dataAbertura     DateTime
  dataDistribuicao DateTime?
  dataPrazo        DateTime?
  dataConclusao    DateTime?
  notas          String?
  cartaPrecatoria Boolean @default(false)
  // Carta Precatória — inspetor titular do inquérito (de outra unidade), a
  // quem o processo é devolvido após as diligências. Campos livres: o titular
  // pode pertencer a outro órgão/unidade e não ser utilizador do sistema.
  titularNome    String?
  titularEmail   String?
  titularVoip    String?
  titularUnidade String?
  // Tribunal / Ministério Público — all optional.
  procurador     String?
  oficialJustica String?
  voip           String?
  notasTribunal  String?
  // Denunciante (queixoso) — all optional. Tipo é 'SINGULAR' | 'COLETIVA'
  // ao nível da aplicação (nullable String para não exigir migração quando
  // surgirem novos tipos). NIF para singulares; NIPC para coletivas.
  denuncianteNome        String?
  denuncianteTipo        String?
  denuncianteNif         String?
  denuncianteMorada      String?
  denuncianteCodPostal   String?
  denuncianteLocalidade  String?
  denuncianteContacto    String?
  denuncianteEmail       String?
  denuncianteResponsavel String?
  denuncianteNotas       String?
  // Documentação pendente — inquérito já enviado/concluído mas a aguardar
  // documentação que chega depois e tem de ser junta a posterior.
  // `documentacaoPendenteNota` descreve o que falta; `...Desde` é preenchido
  // automaticamente ao marcar e limpo ao resolver.
  documentacaoPendente      Boolean   @default(false)
  documentacaoPendenteNota  String?
  documentacaoPendenteDesde DateTime?
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  estado   EstadoInquerito @relation(fields: [estadoId], references: [id])
  estadoId String

  brigada   Brigada? @relation(fields: [brigadaId], references: [id])
  brigadaId String?

  inspetor   Utilizador? @relation("InspetorAtribuido", fields: [inspetorId], references: [id])
  inspetorId String?

  // Quem ativou a marca de documentação pendente — a listagem é privada do
  // autor (cada utilizador só vê as marcas que fez). SetNull se o autor for
  // removido, para não quebrar o inquérito.
  documentacaoPendentePor   Utilizador? @relation("DocumentacaoPendentePor", fields: [documentacaoPendentePorId], references: [id], onDelete: SetNull)
  documentacaoPendentePorId String?

  crime    Crime?  @relation("CrimePrincipal", fields: [crimeId], references: [id])
  crimeId  String?
  // Crimes adicionais (m2m implícita). Não contam para estatísticas —
  // só o crime principal (crimeId) entra nos agrupamentos por crime,
  // garantindo que um inquérito nunca é contado mais de uma vez.
  crimesAssociados Crime[] @relation("CrimesAssociados")

  tribunal   Tribunal? @relation(fields: [tribunalId], references: [id])
  tribunalId String?
  seccao     Seccao? @relation(fields: [seccaoId], references: [id])
  seccaoId   String?

  // Etiquetas (tags) pessoais aplicadas ao inquérito. Relação m2m implícita —
  // o join table `_EtiquetaToInquerito` é gerido pelo Prisma.
  etiquetas Etiqueta[]

  atividades   Atividade[]
  controlos    Controlo[]
  notificacoes Notificacao[]
  documentos   Documento[]
  notasRegisto NotaInquerito[]
  tarefas      TarefaInquerito[]

  // Ligações a outros inquéritos (apensos/conexões). Cada par é guardado uma
  // vez; a leitura é feita nos dois sentidos (ver src/lib/relacoes.ts).
  relacoesOrigem  InqueritoRelacao[] @relation("RelacaoOrigem")
  relacoesDestino InqueritoRelacao[] @relation("RelacaoDestino")

  diligencias     Diligencia[]
  intercecaoAlvos IntercecaoAlvo[]
  colaboradores   InqueritoColaborador[]
  intervenientes  Interveniente[]
  apreensoes      Apreensao[]
  pericias        Pericia[]

  @@index([brigadaId])
  @@index([inspetorId])
  @@index([estadoId])
  @@index([crimeId])
  @@index([dataPrazo])
  @@index([nuipc])
  @@index([updatedAt(sort: Desc)])
  @@index([brigadaId, updatedAt(sort: Desc)])
  @@index([inspetorId, updatedAt(sort: Desc)])
  @@index([deletedAt])
  @@index([tribunalId])
  @@index([seccaoId])
  @@index([cartaPrecatoria])
  @@index([documentacaoPendente])
  @@index([documentacaoPendentePorId])
}

// Papel de um interveniente no inquérito. Lista fixa + OUTRO (com texto livre
// em `tipoOutro`). O denunciante continua a ser um campo próprio do Inquerito;
// estes são intervenientes ADICIONAIS e opcionais.
enum TipoInterveniente {
  LESADO
  VITIMA
  TESTEMUNHA
  ADVOGADO
  ARGUIDO
  PERITO
  OUTRO
}

// Intervenientes adicionais de um inquérito (lesado, vítima, advogado, etc.),
// para além do denunciante. Campos espelham o denunciante (pessoa singular ou
// coletiva). Geridos ao nível do inquérito (mesma permissão do denunciante:
// titular/hierarquia — não é trabalho operacional de colaborador).
model Interveniente {
  id          String            @id @default(cuid())
  tipo        TipoInterveniente
  // Descrição livre do papel quando `tipo` = OUTRO (ignorado nos outros casos).
  tipoOutro   String?
  nome        String
  // 'SINGULAR' | 'COLETIVA' | 'ENTIDADE_PUBLICA' | 'OUTROS' (igual ao denunciante).
  tipoPessoa  String?
  nif         String?
  morada      String?
  codPostal   String?
  localidade  String?
  contacto    String?
  email       String?
  // Responsável/representante (para pessoas coletivas), igual ao denunciante.
  responsavel String?
  notas       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  inquerito   Inquerito @relation(fields: [inqueritoid], references: [id], onDelete: Cascade)
  inqueritoid String

  @@index([inqueritoid])
}

// ── Apreensões (cadeia de custódia de objetos apreendidos) ───────────────────

// Categoria do objeto apreendido (lista fixa + OUTRO com texto livre).
enum TipoApreensao {
  ARMA
  VEICULO
  DINHEIRO
  DROGA
  EQUIPAMENTO_INFORMATICO
  DOCUMENTO
  OUTRO
}

// Situação/destino do objeto na cadeia de custódia.
enum EstadoApreensao {
  EM_CUSTODIA
  A_AGUARDAR_EXAME
  DEVOLVIDO
  PERDIDO_A_FAVOR_ESTADO
  DESTRUIDO
}

// Objeto apreendido num inquérito, com a sua cadeia de custódia. Trabalho
// operacional do inquérito (o acesso segue o scope do inquérito, e a escrita a
// mesma regra das atividades — inclui colaboradores autorizados).
model Apreensao {
  id           String          @id @default(cuid())
  descricao    String          // o que foi apreendido
  tipo         TipoApreensao   @default(OUTRO)
  tipoOutro    String?         // descrição livre quando tipo = OUTRO
  quantidade   String?         // ex.: "3 unidades", "250 g" — texto livre
  numeroAuto   String?         // nº do auto de apreensão
  dataApreensao DateTime
  local        String?         // onde foi apreendido
  apreendidoA  String?         // a quem foi apreendido (texto livre)
  localCustodia String?        // onde está guardado (cofre/depósito)
  estado       EstadoApreensao @default(EM_CUSTODIA)
  dataDestino  DateTime?       // data da devolução / perda / destruição
  observacoes  String?
  // Idempotência do alerta "apreensão parada" (objeto há muito por dar destino).
  alertaParadaEnviado Boolean  @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  inquerito    Inquerito @relation(fields: [inqueritoid], references: [id], onDelete: Cascade)
  inqueritoid  String

  registadoPor   Utilizador @relation("ApreensaoRegistador", fields: [registadoPorId], references: [id])
  registadoPorId String

  // Perícias que incidem sobre este objeto (ligação opcional).
  pericias     Pericia[]  @relation("ApreensaoPericias")

  @@index([inqueritoid])
  @@index([estado])
  @@index([dataApreensao])
}

// Tipo de perícia técnica/científica solicitada (lista fixa + OUTRO).
enum TipoPericia {
  BALISTICA
  ADN
  INFORMATICA_FORENSE
  DOCUMENTAL
  TOXICOLOGICA
  DACTILOSCOPICA
  MEDICO_LEGAL
  FINANCEIRA
  AVALIACAO
  OUTRO
}

// Estado do pedido de perícia.
enum EstadoPericia {
  SOLICITADA
  EM_CURSO
  CONCLUIDA
  CANCELADA
}

// Perícia/exame técnico pedido a uma entidade especializada (LPC, INML, …),
// opcionalmente sobre um objeto apreendido. Trabalho operacional do inquérito
// (mesmo scope/escrita das atividades e apreensões).
model Pericia {
  id               String        @id @default(cuid())
  tipo             TipoPericia   @default(OUTRO)
  tipoOutro        String?       // descrição livre quando tipo = OUTRO
  descricao        String        // objeto/objetivo da perícia
  entidade         String?       // laboratório/entidade (LPC, INML, …)
  numeroReferencia String?       // nº de referência do pedido/exame
  dataPedido       DateTime
  dataPrevista     DateTime?     // data prevista de conclusão (prazo)
  estado           EstadoPericia @default(SOLICITADA)
  dataConclusao    DateTime?
  resultado        String?       // conclusões/resultado
  observacoes      String?
  // Idempotência do alerta "perícia atrasada" (prevista já passou, sem conclusão).
  alertaAtrasoEnviado Boolean    @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  inquerito    Inquerito @relation(fields: [inqueritoid], references: [id], onDelete: Cascade)
  inqueritoid  String

  // Ligação opcional ao objeto apreendido examinado. Ao apagar a apreensão, a
  // perícia mantém-se mas fica sem ligação (SetNull).
  apreensao    Apreensao? @relation("ApreensaoPericias", fields: [apreensaoId], references: [id], onDelete: SetNull)
  apreensaoId  String?

  registadoPor   Utilizador @relation("PericiaRegistador", fields: [registadoPorId], references: [id])
  registadoPorId String

  @@index([inqueritoid])
  @@index([estado])
  @@index([dataPrevista])
  @@index([apreensaoId])
}

// Documentos/anexos de um inquérito (provas, relatórios, ofícios…).
// O ficheiro vive em disco (DOCUMENTOS_DIR) com um nome aleatório (storedName);
// `filename` guarda o nome original apresentado ao utilizador.
model Documento {
  id         String   @id @default(cuid())
  filename   String
  storedName String   @unique
  mimeType   String
  tamanho    Int
  // SHA-256 (hex) do conteúdo, calculado no upload. Serve de referência de
  // integridade (cadeia de custódia): a verificação recalcula o hash do
  // ficheiro em disco e compara. Null em documentos anteriores à feature.
  sha256     String?
  createdAt  DateTime @default(now())

  inquerito   Inquerito @relation(fields: [inqueritoid], references: [id], onDelete: Cascade)
  inqueritoid String

  uploadedBy   Utilizador @relation("DocumentoUploader", fields: [uploadedById], references: [id])
  uploadedById String

  @@index([inqueritoid])
  @@index([uploadedById])
}

// Notas de investigação por inquérito. Cada nota é uma entrada imutável,
// datada e atribuída ao seu autor — em conjunto formam o registo cronológico
// de notas do inquérito. A eliminação (autor ou admin) é registada na auditoria.
model NotaInquerito {
  id        String   @id @default(cuid())
  titulo    String?
  conteudo  String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  inquerito   Inquerito @relation(fields: [inqueritoId], references: [id], onDelete: Cascade)
  inqueritoId String

  autor   Utilizador @relation("NotaInqueritoAutor", fields: [autorId], references: [id])
  autorId String

  // Quem fez a última edição (pode diferir do autor original).
  editadoPor   Utilizador? @relation("NotaInqueritoEditor", fields: [editadoPorId], references: [id])
  editadoPorId String?

  @@index([inqueritoId])
  @@index([autorId])
  @@index([inqueritoId, createdAt])
  @@index([updatedAt])
}

model EstadoInquerito {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nome      String
  descricao String?
  ordem     Int      @default(0)
  terminal  Boolean  @default(false)
  cor       String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inqueritos                            Inquerito[]
  atividadesPadraoQueTransitam          AtividadePadrao[] @relation("AtividadePadraoTransicao")
  atividadesPadraoQueTransitamConclusao AtividadePadrao[] @relation("AtividadePadraoTransicaoConclusao")
  regrasComoOrigem                      RegraTransicaoAutomatica[] @relation("RegraTransicaoOrigem")
  regrasComoDestino                     RegraTransicaoAutomatica[] @relation("RegraTransicaoDestino")

  @@index([ativo, ordem])
}

// Regra de transição automática por inatividade: um inquérito que esteja no
// estado `origem` há mais de `meses` meses SEM qualquer atividade nem mudança
// de estado nesse período é movido automaticamente para `destino` (pelo cron),
// notificando o inspetor. O tempo é parametrizado pelo administrador.
// Uma regra por estado de origem (@@unique) para não haver ambiguidade.
model RegraTransicaoAutomatica {
  id String @id @default(cuid())

  origem   EstadoInquerito @relation("RegraTransicaoOrigem", fields: [origemId], references: [id], onDelete: Cascade)
  origemId String          @unique

  destino   EstadoInquerito @relation("RegraTransicaoDestino", fields: [destinoId], references: [id], onDelete: Cascade)
  destinoId String

  meses Int     // meses de inatividade no estado de origem antes de transitar
  ativa Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([destinoId])
  @@index([ativa])
}

model Crime {
  id        String   @id @default(cuid())
  nome      String   @unique
  descricao String?
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inqueritos          Inquerito[] @relation("CrimePrincipal")
  inqueritoAssociados Inquerito[] @relation("CrimesAssociados")
  checklist           CrimeChecklistItem[]

  @@index([ativo, ordem])
}

// Checklist por tipo de crime: as atividades-padrão que se ESPERAM num
// inquérito deste crime (ex.: burla informática → pedido à operadora,
// preservação de dados, exame ao equipamento). A completude não guarda
// estado próprio — calcula-se contra as atividades já registadas no
// inquérito (existe atividade com o nome do padrão → item feito).
model CrimeChecklistItem {
  id      String @id @default(cuid())
  crime   Crime  @relation(fields: [crimeId], references: [id], onDelete: Cascade)
  crimeId String

  atividadePadrao   AtividadePadrao @relation(fields: [atividadePadraoId], references: [id], onDelete: Cascade)
  atividadePadraoId String

  ordem     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([crimeId, atividadePadraoId])
  @@index([crimeId])
  @@index([atividadePadraoId])
}

model Comarca {
  id        String     @id @default(cuid())
  nome      String     @unique
  ordem     Int        @default(0)
  ativo     Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tribunais Tribunal[]
  seccoes   Seccao[]
  @@index([ativo, ordem])
}

model Tribunal {
  id        String   @id @default(cuid())
  nome      String   @unique
  comarcaId String?
  comarca   Comarca? @relation(fields: [comarcaId], references: [id], onDelete: SetNull)
  morada    String?
  telefone  String?
  email     String?
  descricao String?
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  inqueritos Inquerito[]
  @@index([ativo, ordem])
  @@index([comarcaId])
}

model Seccao {
  id        String   @id @default(cuid())
  nome      String
  descricao String?
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  comarcaId String?
  comarca   Comarca? @relation(fields: [comarcaId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  inqueritos Inquerito[]
  @@index([ativo, ordem])
  @@index([comarcaId])
}


// Etiqueta (tag) pessoal — cada utilizador cria as suas, únicas dentro do seu
// perfil. A unicidade é case-insensitive: garantida por `nomeNormalizado`
// (lower-case de `nome`) com @@unique [criadoPorId, nomeNormalizado], para que
// "Roubo" e "roubo" não possam coexistir. Atribuível a vários inquéritos (m2m
// implícita) para categorização livre — ex.: "Prioritário", "Aguardando MP".
// Uma vez aplicada, a etiqueta "viaja" com o inquérito e fica visível a quem o
// vê, independentemente de quem a criou.
model Etiqueta {
  id          String   @id @default(cuid())
  nome        String
  // Forma normalizada (lower-case de `nome`) usada apenas para impor unicidade
  // case-insensitive por utilizador. Mantida em sincronia em cada escrita.
  nomeNormalizado String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  criadoPor   Utilizador @relation(fields: [criadoPorId], references: [id], onDelete: Cascade)
  criadoPorId String

  inqueritos Inquerito[]

  @@unique([criadoPorId, nomeNormalizado])
  @@index([criadoPorId])
}

model Atividade {
  id             String    @id @default(cuid())
  descricao      String
  observacoes    String?
  quantidade     Int?
  dataPrazo      DateTime?
  alertaDias1    Int?
  alertaDias2    Int?
  alerta1Enviado Boolean   @default(false)
  alerta2Enviado Boolean   @default(false)
  dataRealizacao DateTime  @default(now())
  // When set, the work this atividade represents is "done" — used both by
  // the dashboard counters (Aguarda Exames / Enviados) and the cron to stop
  // firing alerts. Independent of `dataPrazo`: an atividade without a prazo
  // can still be marked as completed (a closed event marker).
  concluidaEm    DateTime?
  createdAt      DateTime  @default(now())

  inquerito   Inquerito @relation(fields: [inqueritoid], references: [id], onDelete: Cascade)
  inqueritoid String

  realizadaPor Utilizador @relation(fields: [utilizadorId], references: [id])
  utilizadorId String

  controlo Controlo?

  @@index([inqueritoid])
  @@index([utilizadorId])
  @@index([inqueritoid, dataRealizacao])
  @@index([dataPrazo])
  @@index([concluidaEm])
}

// Controlos — recurring (or one-time) check-ins, optionally linked to an inquiry.
// periodoDias = null → one-time deadline; > 0 → repeats every N days.
model Controlo {
  id          String    @id @default(cuid())
  descricao   String
  observacoes String?
  dataInicio  DateTime
  periodoDias Int?
  alertaDias  Int       @default(3)
  concluidoEm DateTime?
  createdAt   DateTime  @default(now())

  inqueritoid String?
  inquerito   Inquerito?  @relation(fields: [inqueritoid], references: [id], onDelete: SetNull)

  atividadeId String?   @unique
  atividade   Atividade? @relation(fields: [atividadeId], references: [id], onDelete: SetNull)

  criadorId   String
  criador     Utilizador  @relation("ControloCriador", fields: [criadorId], references: [id])

  realizacoes ControloRealizacao[]

  @@index([inqueritoid])
  @@index([criadorId])
  @@index([dataInicio])
}

// Each numbered occurrence of a Controlo (1.º Controlo, 2.º Controlo, …).
model ControloRealizacao {
  id             String    @id @default(cuid())
  numero         Int
  dataEsperada   DateTime
  dataRealizacao DateTime?
  observacoes    String?
  alertaEnviado  Boolean   @default(false)
  createdAt      DateTime  @default(now())

  controlo    Controlo   @relation(fields: [controloId], references: [id], onDelete: Cascade)
  controloId  String

  realizadoPorId String?
  realizadoPor   Utilizador? @relation("ControloRealizacaoPor", fields: [realizadoPorId], references: [id], onDelete: SetNull)

  @@unique([controloId, numero])
  @@index([controloId])
  @@index([dataEsperada])
}

model Notificacao {
  id           String          @id @default(cuid())
  tipo         TipoNotificacao
  titulo       String
  mensagem     String
  lida         Boolean         @default(false)
  limpa        Boolean         @default(false)
  emailEnviado Boolean         @default(false)
  createdAt    DateTime        @default(now())

  utilizador   Utilizador @relation(fields: [utilizadorId], references: [id], onDelete: Cascade)
  utilizadorId String

  inquerito   Inquerito? @relation(fields: [inqueritoid], references: [id], onDelete: SetNull)
  inqueritoid String?

  @@index([utilizadorId, lida])
  @@index([utilizadorId, limpa])
  @@index([utilizadorId, createdAt])
  @@index([createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  acao         String
  entidade     String
  entidadeId   String
  utilizadorId String
  detalhes     Json?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([entidade, entidadeId])
  @@index([utilizadorId])
  @@index([createdAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String?
  userAgent String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ip, createdAt])
  @@index([createdAt])
}

model ConfiguracaoSistema {
  id                              String   @id @default("singleton")
  backupScheduleCron              String   @default("0 2 * * *")
  // Número de ficheiros de backup a manter por prefixo (rotação FIFO).
  // Passado como BACKUP_RETENTION ao backup.sh pelo worker.
  backupRetencao                  Int      @default(30)
  // Quando true, o middleware bloqueia utilizadores não-ADMINISTRACAO com 503.
  // Activado/desactivado pelo endpoint de restauro e disponível como toggle
  // manual em /configurações para janelas de manutenção planeadas.
  maintenanceMode                 Boolean  @default(false)
  // When false, the Ajudas Mensais module is hidden and all its API routes
  // return 503. Only ADMINISTRACAO can toggle this in Configurações → Sistema.
  moduloAjudasAtivo               Boolean  @default(true)
  // Comma-separated list of Role values that can access the Ajudas module when
  // it is active. ADMINISTRACAO always has access and is never stored here.
  moduloAjudasRoles               String   @default("INSPETOR,INSPETOR_CHEFE,COORDENADOR")
  // When false, the Férias module is hidden and all its API routes return 503.
  // Only ADMINISTRACAO can toggle this in Configurações → Sistema.
  moduloFeriasAtivo               Boolean  @default(true)
  // Comma-separated list of Role values that can access the Férias module when
  // it is active. ADMINISTRACAO always has access and is never stored here.
  moduloFeriasRoles               String   @default("INSPETOR,INSPETOR_CHEFE,COORDENADOR")
  // When false, users can no longer submit bug reports (the /reportar-bug page
  // and its POST route return "module disabled"). The ADMINISTRACAO management
  // page (/bugs) is always available so existing reports can still be analysed.
  moduloBugReportsAtivo           Boolean  @default(true)
  // Comma-separated list of Role values allowed to submit bug reports when the
  // module is active. ADMINISTRACAO always has access and is never stored here.
  moduloBugReportsRoles           String   @default("INSPETOR,INSPETOR_CHEFE,COORDENADOR")
  // When false, the Toolbox module (investigator utilities: IP lookup, email
  // header analysis, DNS, etc.) is hidden and its API routes return 503.
  moduloToolboxAtivo              Boolean  @default(true)
  // Comma-separated list of Role values allowed to use the Toolbox when the
  // module is active. ADMINISTRACAO always has access and is never stored here.
  moduloToolboxRoles              String   @default("INSPETOR,INSPETOR_CHEFE,COORDENADOR")
  // When false, the Anexos feature (documentos anexados a inquéritos) is hidden
  // on the inquiry detail page and its API routes return 503. Only ADMINISTRACAO
  // can toggle this in Configurações → Sistema.
  moduloAnexosAtivo               Boolean  @default(true)
  // Comma-separated list of Role values allowed to see/manage attachments when
  // the module is active. ADMINISTRACAO always has access and is never stored here.
  moduloAnexosRoles               String   @default("INSPETOR,INSPETOR_CHEFE,COORDENADOR")
  // When false, the Agenda module (vista de calendário: prazos, atividades,
  // controlos e diligências) is hidden and its API routes return 503. Only
  // ADMINISTRACAO can toggle this in Configurações → Sistema.
  moduloAgendaAtivo               Boolean  @default(true)
  // Comma-separated list of Role values allowed to use the Agenda when the
  // module is active. ADMINISTRACAO always has access and is never stored here.
  moduloAgendaRoles               String   @default("INSPETOR,INSPETOR_CHEFE,COORDENADOR")
  // Módulo Interceções (controlo de escutas): quando desativado, a navegação
  // esconde a página e as rotas API devolvem 503. ADMINISTRACAO tem sempre acesso.
  moduloIntercecoesAtivo          Boolean  @default(true)
  moduloIntercecoesRoles          String   @default("INSPETOR,INSPETOR_CHEFE,COORDENADOR")
  // Módulo Apreensões (cadeia de custódia de objetos apreendidos).
  moduloApreensoesAtivo           Boolean  @default(true)
  moduloApreensoesRoles           String   @default("INSPETOR,INSPETOR_CHEFE,COORDENADOR")
  // Dias em custódia após os quais um objeto ainda por devolver/dar destino
  // gera um lembrete (APREENSAO_PARADA) ao inspetor. null/0 = desligado.
  apreensaoAlertaDias             Int?     @default(180)
  // Módulo Perícias (exames técnicos/científicos pedidos a entidades externas).
  moduloPericiasAtivo             Boolean  @default(true)
  moduloPericiasRoles             String   @default("INSPETOR,INSPETOR_CHEFE,COORDENADOR")
  // Explicações por IA na Toolbox (LLM local via Ollama). Opt-in: o admin só
  // deve ativar depois de descarregar o modelo no container Ollama.
  toolboxIaAtivo                  Boolean  @default(false)
  toolboxIaModelo                 String   @default("qwen3:4b")
  // Idle timeout in minutes. 0 disables the feature.
  sessaoTimeoutMinutos            Int      @default(0)
  prazoAlertaDias                 Int      @default(7)
  // Segundo limiar (opcional, mais próximo do prazo) para um aviso "urgente"
  // de inquéritos: quando o prazo cai dentro deste nº de dias, escala também
  // ao Inspetor-Chefe da brigada. null = desligado.
  prazoAlertaDiasUrgente          Int?
  emailRemetenteNome              String   @default("GPI Sistema")
  emailRemetenteAddr              String   @default("noreply@gpi.pt")
  // Ligação ao servidor SMTP, configurável pelo ADMINISTRACAO em
  // /configurações → Sistema. Quando smtpHost está definido, sobrepõe-se às
  // variáveis de ambiente SMTP_*; caso contrário usa-se o fallback de env.
  // A palavra-passe é guardada cifrada (AES-256-GCM, ver src/lib/crypto-secrets.ts)
  // e nunca é devolvida em texto pela API.
  smtpHost                        String?
  smtpPort                        Int?
  smtpSecure                      Boolean  @default(false)
  smtpUser                        String?
  smtpPasswordEnc                 String?
  // Módulo de notificações por email. false = nenhum email é enviado pelo sistema,
  // independentemente das políticas por tipo. Útil durante fases de teste/integração.
  emailNotificacoesAtivo          Boolean  @default(true)
  // Template (global) dos e-mails de notificação — formulário estruturado
  // (cabeçalho/cor/saudação/rodapé/aviso legal/prefixo do assunto). null = usar
  // os defaults de src/lib/email-template.ts. Ver EmailTemplate.
  emailTemplate                   Json?
  // Default estado codigos applied to /inqueritos when the user has no explicit
  // filter set on the URL. Stored as codigos for stability across renames.
  inqueritoFiltroEstadosDefault   String[] @default([])
  // Cache da última verificação à GitHub Releases. Escrito pelo worker no
  // tick agendado e pelo endpoint POST /api/updates/check.
  latestVersionTag                String?
  latestVersionCheckedAt          DateTime?
  latestVersionUrl                String?
  latestVersionNotes              String?
  // Personalização (branding) — null em qualquer campo = usar o default
  // codificado em src/lib/brand-defaults.ts. Os ficheiros referenciados
  // (logos, favicon) vivem em BRANDING_DIR (bind mount ./branding).
  // brandUpdatedAt é usado como cache-busting `?v=<ts>` para os assets.
  appName                         String?
  appShortName                    String?
  appDescription                  String?
  manifestDescription             String?
  pdfFooterText                   String?
  // Cabeçalho/título e marca de água dos PDFs (impressão do inquérito e
  // relatórios). null = usar o default (cabeçalho vazio, sem marca de água).
  pdfHeaderText                   String?
  pdfWatermarkText                String?
  appAuthor                       String?
  logoLightFilename               String?
  logoDarkFilename                String?
  faviconFilename                 String?
  logoHorizontalLightFilename     String?
  logoHorizontalDarkFilename      String?
  // Escala em % (10–200) e alinhamento (left|center|right) do logo horizontal na sidebar.
  logoHorizontalEscala            Int      @default(100)
  logoHorizontalAlinhamento       String   @default("center")
  brandUpdatedAt                  DateTime?
  updatedAt                       DateTime @updatedAt
}

// Cada tentativa de atualização da app deixa uma linha aqui. A FSM (campo
// `state`) é validada em escrita por src/lib/updates/state-machine.ts; este
// modelo é o ponto único de verdade observado pelo UI e pelo audit.
model AtualizacaoSistema {
  id              String   @id @default(cuid())
  // Idempotency key passada pelo cliente (header Idempotency-Key). Permite
  // que retries da request POST /api/updates/start não criem duplicados.
  requestId       String   @unique
  fromVersion     String
  toVersion       String
  fromCommitSha   String
  toCommitSha     String?
  // Nome do estado da FSM. Strings em vez de enum para evitar migrações
  // sempre que se adiciona um estado intermédio.
  state           String
  // Filename do gpi_prerestore_*.sql.gz criado antes do update, usado pelo
  // path de rollback para reverter a BD.
  preBackupFile   String?
  startedAt       DateTime @default(now())
  finishedAt      DateTime?
  errorMessage    String?
  rolledBack      Boolean  @default(false)
  iniciadoPorId   String
  iniciadoPor     Utilizador @relation(fields: [iniciadoPorId], references: [id])

  @@index([startedAt])
  @@index([state])
}

model AtividadePadrao {
  id                    String   @id @default(cuid())
  nome                  String   @unique
  descricao             String?
  ativa                 Boolean  @default(true)
  ordem                 Int      @default(0)
  temPrazo              Boolean  @default(false)
  temQuantidade         Boolean  @default(false)
  temControlo           Boolean  @default(false)
  // When false, activities of this type are excluded from analytical
  // aggregations (e.g. "Resumo por tipo" in the inquérito detail). The total
  // count of activities is unaffected.
  contaParaEstatistica  Boolean  @default(true)
  // Optional auto-transition: when an Atividade with this padrão's `nome` is
  // created, the parent inquérito is moved to this estado (subject to the
  // state machine). Null means no transition.
  transicaoEstado   EstadoInquerito? @relation("AtividadePadraoTransicao", fields: [transicaoEstadoId], references: [id], onDelete: SetNull)
  transicaoEstadoId String?
  // Optional auto-transition on CONFIRMATION: when an Atividade of this padrão
  // is marked as concluded (confirmação de devolução / conclusão de exames), the
  // parent inquérito moves to this estado (subject to the state machine). Null
  // means no transition on conclusion. Parametrizável pelo administrador.
  transicaoEstadoConclusao   EstadoInquerito? @relation("AtividadePadraoTransicaoConclusao", fields: [transicaoEstadoConclusaoId], references: [id], onDelete: SetNull)
  transicaoEstadoConclusaoId String?
  // Optional category for the dashboard counters. Values are an app-level
  // union ('AGUARDA_EXAMES' | 'ENVIADO'); kept as a nullable String so new
  // categories can be added without a Prisma migration.
  categoriaDashboard String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  checklistItems CrimeChecklistItem[]

  @@index([transicaoEstadoId])
  @@index([transicaoEstadoConclusaoId])
  @@index([categoriaDashboard])
}

enum AjudasPrevencao {
  NENHUMA
  PIQUETE
  PREVENCAO_PASSIVA
}

enum AjudasViatura {
  PROPRIA
  BRIGADA
}

model Viatura {
  id           String        @id @default(cuid())
  utilizadorId String
  utilizador   Utilizador    @relation(fields: [utilizadorId], references: [id], onDelete: Cascade)
  nome         String
  matricula    String?       @unique
  ativo        Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  linhas       AjudasLinha[]

  @@index([utilizadorId])
}

// Singleton config for Ajudas Mensais - managed by ADMINISTRACAO
model AjudasConfig {
  id                      String   @id @default("default")
  vencimentoE25           Float    @default(1974.41)
  vencimentoDN            Float    @default(7143.207)
  percentPiqueteSemana    Float    @default(0.083)
  percentPiqueteFds       Float    @default(0.105)
  percentPrevencaoPassiva Float    @default(0.4)
  senhaAlmoco             Float    @default(9.60)
  senhaJantar             Float    @default(8.23)
  senhaCeia               Float    @default(4.24)
  taxaIRS                 Float    @default(0.1116)
  taxaSS                  Float    @default(0.11)
  distanciaMinKmAjudas    Int      @default(35)
  updatedAt               DateTime @updatedAt
}

// Monthly record per inspector (auto-created on first access)
model AjudasRegisto {
  id           String        @id @default(cuid())
  utilizadorId String
  utilizador   Utilizador    @relation(fields: [utilizadorId], references: [id], onDelete: Cascade)
  ano          Int
  mes          Int           // 1-12
  linhas       AjudasLinha[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([utilizadorId, ano, mes])
  @@index([utilizadorId])
}

// Individual callout/activity entry
model AjudasLinha {
  id                   String          @id @default(cuid())
  registoId            String
  registo              AjudasRegisto   @relation(fields: [registoId], references: [id], onDelete: Cascade)
  nuipc                String?
  local                String?
  dataInicio           DateTime
  dataFim              DateTime
  prevencao            AjudasPrevencao @default(NENHUMA)
  // When true, this entry records only a prevencao/piquete fee (no overtime hours).
  // splitHours is skipped; only the prevencao period is counted.
  prevencaoOnly        Boolean         @default(false)
  ajudaCustoAlmoco     Int             @default(0)
  ajudaCustoJantar     Int             @default(0)
  ajudaCustoCeia       Int             @default(0)
  senhaAlmoco          Int             @default(0)
  senhaJantar          Int             @default(0)
  senhaCeia            Int             @default(0)
  viaturaId            String?
  viatura              Viatura?        @relation(fields: [viaturaId], references: [id], onDelete: SetNull)
  km                   Int             @default(0)
  observacoes          String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([registoId])
  @@index([viaturaId])
}

// Vacation / days-off marking by an inspector. View-only for the chefe (no
// approval flow). Dates are date-only (local midnight) and inclusive.
model Ausencia {
  id         String       @id @default(cuid())
  inspetorId String
  inspetor   Utilizador   @relation("AusenciasInspetor", fields: [inspetorId], references: [id], onDelete: Cascade)
  // Snapshot of inspetor.brigadaId at create time — keeps brigade queries fast
  // and stable even if the inspector later changes brigade.
  brigadaId  String?
  brigada    Brigada?     @relation(fields: [brigadaId], references: [id], onDelete: SetNull)
  tipo       TipoAusencia
  dataInicio DateTime
  dataFim    DateTime
  nota       String?
  deletedAt  DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([inspetorId])
  @@index([brigadaId])
  @@index([deletedAt])
  @@index([inspetorId, dataInicio])
}

model Sessao {
  id           String     @id @default(cuid())
  sessionToken String     @unique
  expires      DateTime

  utilizador   Utilizador @relation(fields: [utilizadorId], references: [id], onDelete: Cascade)
  utilizadorId String
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Token de reset de password. O `tokenHash` é o SHA-256 do valor enviado
// por email — o servidor nunca grava o token em claro, pelo que comprometer
// a BD não dá acesso retro-activo a contas via tokens activos.
//
// `usedAt` marca tokens já consumidos (single-use). `expiresAt` é o cutoff
// duro (1h após emissão por defeito). Tokens expirados ou usados continuam
// na tabela como audit trail até a limpeza periódica os apagar.
model PasswordResetToken {
  id           String    @id @default(cuid())
  tokenHash    String    @unique
  utilizadorId String
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())
  ip           String?
  userAgent    String?

  utilizador Utilizador @relation(fields: [utilizadorId], references: [id], onDelete: Cascade)

  @@index([utilizadorId])
  @@index([expiresAt])
}

// Política de envio por tipo de notificação. Uma row por TipoNotificacao
// (PK = tipo). Editável pelo ADMINISTRACAO em /configurações → Notificações.
//
// Semântica de envio:
//   - inAppEnabled: cria linha em Notificacao
//   - emailEnabled: chama sendMail() (continua a respeitar DISABLE_EMAIL global)
//   - ccRoles: utilizadores com estes roles recebem em adição ao destinatário
//     "natural" do contexto (inspetor do inquérito, criador da atividade, ...).
//     Lista vazia = só o destinatário natural; ['ADMINISTRACAO'] = todos os
//     admins activos também recebem.
//
// O seed cria a row faltante para cada valor do enum (idempotente). Se o
// enum ganhar um tipo novo, a próxima boot cria a row com defaults.
model NotificationPolicy {
  tipo         TipoNotificacao @id
  inAppEnabled Boolean         @default(true)
  emailEnabled Boolean         @default(true)
  ccRoles      Role[]          @default([])
  updatedAt    DateTime        @updatedAt
}

// Preferência de email por utilizador e por tipo de notificação. Permite a
// cada utilizador optar por NÃO receber emails de um dado tipo (o in-app
// mantém-se sempre, controlado pela NotificationPolicy global). A ausência de
// linha significa "ativo" (default on) — só guardamos opt-outs explícitos.
model NotificacaoPreferencia {
  utilizadorId String
  tipo         TipoNotificacao
  emailEnabled Boolean         @default(true)
  utilizador   Utilizador      @relation(fields: [utilizadorId], references: [id], onDelete: Cascade)

  @@id([utilizadorId, tipo])
}

// Relatório de bug submetido por um utilizador para análise do ADMINISTRACAO.
// Centralizado em /bugs (gestão admin); submetido em /reportar-bug. O módulo
// pode ser ligado/desligado em Configurações → Sistema.
model BugReport {
  id          String        @id @default(cuid())
  titulo      String
  descricao   String
  severidade  SeveridadeBug @default(MEDIA)
  estado      EstadoBug     @default(ABERTO)
  // Página/contexto onde o bug foi observado (path ou URL), opcional.
  pagina      String?
  // Nota interna do administrador ao triar/analisar o report.
  notaAdmin   String?
  criadoPor   Utilizador    @relation(fields: [criadoPorId], references: [id], onDelete: Cascade)
  criadoPorId String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([estado, createdAt])
  @@index([criadoPorId])
  @@index([createdAt])
}

enum PrioridadeTarefa {
  BAIXA
  NORMAL
  ALTA
}

model TarefaInquerito {
  id          String          @id @default(cuid())
  titulo      String
  descricao   String?
  prioridade  PrioridadeTarefa @default(NORMAL)
  concluida   Boolean         @default(false)
  concluidaEm DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt

  inquerito   Inquerito @relation(fields: [inqueritoId], references: [id], onDelete: Cascade)
  inqueritoId String

  autor   Utilizador @relation(fields: [autorId], references: [id])
  autorId String

  @@index([autorId])
  @@index([inqueritoId])
  @@index([autorId, concluida])
  @@index([autorId, prioridade])
}

// Ligação entre dois inquéritos (apensos / conexões / relacionados).
//
// Cada par é guardado UMA única vez (origem→destino). A relação é simétrica: a
// leitura (src/lib/relacoes.ts) procura nos dois sentidos, pelo que o inquérito
// de destino também "vê" o de origem. O `tipo` aplica-se ao par. A criação
// recusa auto-ligações (origem==destino) e duplicados em qualquer sentido (a
// verificação do sentido inverso é feita na API; o @@unique cobre o sentido
// directo). Não confundir com `crimesAssociados` (crimes do mesmo inquérito).
model InqueritoRelacao {
  id          String               @id @default(cuid())
  origemId    String
  destinoId   String
  tipo        TipoRelacaoInquerito @default(RELACIONADO)
  nota        String?
  criadoPorId String
  createdAt   DateTime             @default(now())

  origem    Inquerito  @relation("RelacaoOrigem", fields: [origemId], references: [id], onDelete: Cascade)
  destino   Inquerito  @relation("RelacaoDestino", fields: [destinoId], references: [id], onDelete: Cascade)
  criadoPor Utilizador @relation("RelacaoCriador", fields: [criadoPorId], references: [id])

  @@unique([origemId, destinoId])
  @@index([origemId])
  @@index([destinoId])
  @@index([criadoPorId])
}

// Diligência / evento de agenda — datas de tribunal (julgamentos, inquirições),
// buscas, interrogatórios e outros atos com data marcada. Opcionalmente ligada a
// um inquérito. Alimenta a vista de calendário (Agenda) em conjunto com os
// prazos de inquérito, atividades com prazo e controlos. Visibilidade por role
// em src/lib/role-scope.ts (buildDiligenciaWhere).
model Diligencia {
  id          String         @id @default(cuid())
  titulo      String
  tipo        TipoDiligencia @default(OUTRA)
  dataInicio  DateTime
  dataFim     DateTime?
  local       String?
  observacoes String?
  concluida   Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  inquerito   Inquerito? @relation(fields: [inqueritoId], references: [id], onDelete: SetNull)
  inqueritoId String?

  criadoPor   Utilizador @relation("DiligenciaCriador", fields: [criadoPorId], references: [id])
  criadoPorId String

  @@index([inqueritoId])
  @@index([criadoPorId])
  @@index([dataInicio])
}

// ── Interceções de comunicações (escutas) ────────────────────────────────────
// Espelha o documento de controlo em Excel: um ALVO (suspeito com código) tem
// LINHAS intercetadas (SIM/IMEI com datas de autorização e alertas de fim) e
// um registo de PRODUTOS de interesse (sessões relevantes). Dados do inquérito
// — o acesso segue o scope do inquérito, não o criador.

model IntercecaoAlvo {
  id          String  @id @default(cuid())
  nome        String  // suspeito
  observacoes String?
  // Notas livres do inspetor sobre o alvo (informação considerada relevante).
  notas       String?
  // Até onde o inspetor já acompanhou/reviu as interceções — para saber por
  // onde recomeçar numa próxima sessão. Sempre visível na UI (não é um campo
  // "escondido" atrás de um diálogo).
  acompanhamento String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inquerito   Inquerito @relation(fields: [inqueritoid], references: [id], onDelete: Cascade)
  inqueritoid String

  linhas   IntercecaoLinha[]
  produtos IntercecaoProduto[]

  @@index([inqueritoid])
}

// Uma linha intercetada (cartão SIM, equipamento IMEI, …) com o período
// autorizado. Até 2 alertas antes do fim (dias por linha, padrão Atividade);
// os flags *Enviado garantem idempotência e são REPOSTOS quando dataFim ou os
// dias de alerta mudam (ao contrário do padrão antigo, adiar o fim re-alerta).
// Cada linha tem o seu PRÓPRIO código de alvo (o alvo não tem um código
// único — cada tipo de interceção associado ao alvo tem o seu código próprio
// no sistema de interceção, ex.: SIM = "123-A", IMEI = "123-B").
model IntercecaoLinha {
  id            String   @id @default(cuid())
  codigo        String   // código do alvo associado a ESTA interceção (ex.: "123")
  tipo          TipoLinhaIntercecao
  identificador String   // nº de telefone ou IMEI
  rede          String?  // operadora (MEO, Vodafone, NOS, …)
  dataInicio    DateTime
  dataFim       DateTime
  alertaDias1   Int?     @default(10)
  alertaDias2   Int?     @default(3)
  alerta1Enviado Boolean @default(false)
  alerta2Enviado Boolean @default(false)
  // Nº de renovações (prorrogações) da autorização — incrementado ao renovar.
  renovacoes    Int      @default(0)
  observacoes   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  alvo   IntercecaoAlvo @relation(fields: [alvoId], references: [id], onDelete: Cascade)
  alvoId String

  produtos IntercecaoProduto[]

  @@unique([alvoId, codigo])
  @@index([alvoId])
  @@index([dataFim])
}

// Produto de interesse (sessão relevante) registado manualmente — espelha as
// colunas da folha por alvo do Excel. `linha` é opcional: apagar a linha não
// apaga o registo (SetNull).
model IntercecaoProduto {
  id            String   @id @default(cuid())
  tipo          TipoProdutoIntercecao
  numeroProduto String?  // nº do produto/sessão no sistema de interceção
  direcao       DirecaoProdutoIntercecao?
  data          DateTime
  horaInicio    String?  // "HH:mm"
  horaFim       String?  // "HH:mm"
  duracao       String?  // duração (mm:ss ou hh:mm:ss), sobretudo para chamadas
  // Marcado pelo inspetor como candidato a transcrição.
  paraTranscricao Boolean @default(false)
  de            String?
  para          String?
  resumo        String
  comentarios   String?
  createdAt     DateTime @default(now())

  alvo   IntercecaoAlvo @relation(fields: [alvoId], references: [id], onDelete: Cascade)
  alvoId String

  linha   IntercecaoLinha? @relation(fields: [linhaId], references: [id], onDelete: SetNull)
  linhaId String?

  criadoPor   Utilizador @relation("IntercecaoProdutoCriador", fields: [criadoPorId], references: [id])
  criadoPorId String

  @@index([alvoId, data])
  @@index([alvoId])
  @@index([linhaId])
  @@index([criadoPorId])
}

// Colaboração autorizada — um inspetor a quem o inquérito NÃO está distribuído
// pode, mediante autorização do titular (ou da hierarquia), trabalhar no
// processo (registar atividades, notas, documentos, controlos e interceções).
// NÃO concede poder sobre o processo em si: o colaborador não altera estado/
// prazo/titular, não apaga, e não pode re-delegar acesso a terceiros. A
// autorização é por inquérito, revogável a qualquer momento e opcionalmente
// com data de expiração (após a qual deixa de valer automaticamente).
model InqueritoColaborador {
  id        String  @id @default(cuid())
  // Motivo/âmbito da autorização (livre) — para contexto no histórico.
  motivo    String?
  // Quando definido, a autorização deixa de valer a partir desta data/hora.
  // Null = vale até ser revogada manualmente.
  expiraEm  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inquerito   Inquerito @relation(fields: [inqueritoid], references: [id], onDelete: Cascade)
  inqueritoid String

  // O inspetor autorizado a colaborar.
  colaborador   Utilizador @relation("ColaboradorInquerito", fields: [colaboradorId], references: [id], onDelete: Cascade)
  colaboradorId String

  // Quem concedeu a autorização (titular ou hierarquia). SetNull para não
  // apagar a autorização se o utilizador que a concedeu for removido.
  concedidoPor   Utilizador? @relation("ColaboradorConcedidoPor", fields: [concedidoPorId], references: [id], onDelete: SetNull)
  concedidoPorId String?

  @@unique([inqueritoid, colaboradorId])
  @@index([inqueritoid])
  @@index([colaboradorId])
  @@index([expiraEm])
}
