generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  INSPETOR
  INSPETOR_CHEFE
  COORDENADOR
  ESTATISTICA
  ADMINISTRACAO
}

enum TipoAusencia {
  FERIAS
  FOLGA
}

enum TipoNotificacao {
  BACKUP_FALHOU
  PRAZO_APROXIMANDO
  PRAZO_ULTRAPASSADO
  ATIVIDADE_ADICIONADA
  INQUERITO_ATRIBUIDO
  INQUERITO_TRANSFERIDO
  ATIVIDADE_PRAZO_APROXIMANDO
  ATUALIZACAO_FALHOU
  ATUALIZACAO_CONCLUIDA
  BUGREPORT_CRIADO
  CONTROLO_APROXIMANDO
}

enum SeveridadeBug {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

enum EstadoBug {
  ABERTO
  EM_ANALISE
  RESOLVIDO
  REJEITADO
}

model Brigada {
  id          String   @id @default(cuid())
  nome        String   @unique
  descricao   String?
  ativa       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  utilizadores Utilizador[]
  inqueritos   Inquerito[]
  ausencias    Ausencia[]
}

model Utilizador {
  id           String   @id @default(cuid())
  nome         String
  email        String   @unique
  // Internal identification number (e.g. "número de LT"). Unique when set,
  // optional so legacy accounts and seed users don't have to backfill yet.
  lt           Int?     @unique
  telemovel    String?
  passwordHash String
  role         Role
  ativo        Boolean  @default(true)
  chefeSupremo Boolean  @default(false)
  tokenVersion Int      @default(0)
  lockedUntil  DateTime?
  failedLoginCount Int  @default(0)
  lastLoginAt  DateTime?
  lastLoginIp  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  brigada   Brigada? @relation(fields: [brigadaId], references: [id])
  brigadaId String?

  inqueritos           Inquerito[]   @relation("InspetorAtribuido")
  atividadesRealizadas Atividade[]
  notificacoes         Notificacao[]
  sessoes              Sessao[]
  passwordResetTokens  PasswordResetToken[]
  atualizacoesIniciadas AtualizacaoSistema[]
  etiquetas            Etiqueta[]
  ajudasRegistos       AjudasRegisto[]
  // Per-user overrides for Ajudas Mensais calculations.
  // When set, these take precedence over the global AjudasConfig values.
  ajudasVencimentoBase Float?
  ajudasTaxaIRS        Float?
  viaturas             Viatura[]
  ausencias            Ausencia[]    @relation("AusenciasInspetor")
  notificacaoPreferencias NotificacaoPreferencia[]
  bugReports           BugReport[]
  controlosCriados     Controlo[]   @relation("ControloCriador")
  controloRealizacoes  ControloRealizacao[] @relation("ControloRealizacaoPor")
  documentosCarregados Documento[]  @relation("DocumentoUploader")
  notasInquerito       NotaInquerito[] @relation("NotaInqueritoAutor")
  notasEditadas        NotaInquerito[] @relation("NotaInqueritoEditor")
  tarefasInquerito     TarefaInquerito[]

  @@index([brigadaId])
  @@index([role])
  @@index([brigadaId, role])
}

model Inquerito {
  id             String   @id @default(cuid())
  nuipc          String   @unique
  nai            String?  @unique
  // Free-text natureza, kept for transitional backfill. Once `crimeId` is
  // populated for every row (via scripts/migrate-natureza-to-crime.ts) and
  // the UI no longer reads from this field, a future migration drops it.
  natureza       String
  dataAbertura     DateTime
  dataDistribuicao DateTime?
  dataPrazo        DateTime?
  dataConclusao    DateTime?
  notas          String?
  cartaPrecatoria Boolean @default(false)
  // Tribunal / Ministério Público — all optional.
  procurador     String?
  oficialJustica String?
  voip           String?
  notasTribunal  String?
  // Denunciante (queixoso) — all optional. Tipo é 'SINGULAR' | 'COLETIVA'
  // ao nível da aplicação (nullable String para não exigir migração quando
  // surgirem novos tipos). NIF para singulares; NIPC para coletivas.
  denuncianteNome        String?
  denuncianteTipo        String?
  denuncianteNif         String?
  denuncianteMorada      String?
  denuncianteCodPostal   String?
  denuncianteLocalidade  String?
  denuncianteContacto    String?
  denuncianteEmail       String?
  denuncianteResponsavel String?
  denuncianteNotas       String?
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  estado   EstadoInquerito @relation(fields: [estadoId], references: [id])
  estadoId String

  brigada   Brigada? @relation(fields: [brigadaId], references: [id])
  brigadaId String?

  inspetor   Utilizador? @relation("InspetorAtribuido", fields: [inspetorId], references: [id])
  inspetorId String?

  crime    Crime?  @relation("CrimePrincipal", fields: [crimeId], references: [id])
  crimeId  String?
  // Crimes adicionais (m2m implícita). Não contam para estatísticas —
  // só o crime principal (crimeId) entra nos agrupamentos por crime,
  // garantindo que um inquérito nunca é contado mais de uma vez.
  crimesAssociados Crime[] @relation("CrimesAssociados")

  tribunal   Tribunal? @relation(fields: [tribunalId], references: [id])
  tribunalId String?
  seccao     Seccao? @relation(fields: [seccaoId], references: [id])
  seccaoId   String?

  // Etiquetas (tags) pessoais aplicadas ao inquérito. Relação m2m implícita —
  // o join table `_EtiquetaToInquerito` é gerido pelo Prisma.
  etiquetas Etiqueta[]

  atividades   Atividade[]
  controlos    Controlo[]
  notificacoes Notificacao[]
  documentos   Documento[]
  notasRegisto NotaInquerito[]
  tarefas      TarefaInquerito[]

  @@index([brigadaId])
  @@index([inspetorId])
  @@index([estadoId])
  @@index([crimeId])
  @@index([dataPrazo])
  @@index([nuipc])
  @@index([nai])
  @@index([updatedAt(sort: Desc)])
  @@index([brigadaId, updatedAt(sort: Desc)])
  @@index([inspetorId, updatedAt(sort: Desc)])
  @@index([deletedAt])
  @@index([tribunalId])
  @@index([seccaoId])
  @@index([cartaPrecatoria])
}

// Documentos/anexos de um inquérito (provas, relatórios, ofícios…).
// O ficheiro vive em disco (DOCUMENTOS_DIR) com um nome aleatório (storedName);
// `filename` guarda o nome original apresentado ao utilizador.
model Documento {
  id         String   @id @default(cuid())
  filename   String
  storedName String   @unique
  mimeType   String
  tamanho    Int
  createdAt  DateTime @default(now())

  inquerito   Inquerito @relation(fields: [inqueritoid], references: [id], onDelete: Cascade)
  inqueritoid String

  uploadedBy   Utilizador @relation("DocumentoUploader", fields: [uploadedById], references: [id])
  uploadedById String

  @@index([inqueritoid])
  @@index([uploadedById])
}

// Notas de investigação por inquérito. Cada nota é uma entrada imutável,
// datada e atribuída ao seu autor — em conjunto formam o registo cronológico
// de notas do inquérito. A eliminação (autor ou admin) é registada na auditoria.
model NotaInquerito {
  id        String   @id @default(cuid())
  titulo    String?
  conteudo  String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  inquerito   Inquerito @relation(fields: [inqueritoId], references: [id], onDelete: Cascade)
  inqueritoId String

  autor   Utilizador @relation("NotaInqueritoAutor", fields: [autorId], references: [id])
  autorId String

  // Quem fez a última edição (pode diferir do autor original).
  editadoPor   Utilizador? @relation("NotaInqueritoEditor", fields: [editadoPorId], references: [id])
  editadoPorId String?

  @@index([inqueritoId])
  @@index([autorId])
  @@index([inqueritoId, createdAt])
  @@index([updatedAt])
}

model EstadoInquerito {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nome      String
  descricao String?
  ordem     Int      @default(0)
  terminal  Boolean  @default(false)
  cor       String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inqueritos                   Inquerito[]
  atividadesPadraoQueTransitam AtividadePadrao[]

  @@index([ativo, ordem])
}

model Crime {
  id        String   @id @default(cuid())
  nome      String   @unique
  descricao String?
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inqueritos          Inquerito[] @relation("CrimePrincipal")
  inqueritoAssociados Inquerito[] @relation("CrimesAssociados")

  @@index([ativo, ordem])
}

model Comarca {
  id        String     @id @default(cuid())
  nome      String     @unique
  ordem     Int        @default(0)
  ativo     Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tribunais Tribunal[]
  seccoes   Seccao[]
  @@index([ativo, ordem])
}

model Tribunal {
  id        String   @id @default(cuid())
  nome      String   @unique
  comarcaId String?
  comarca   Comarca? @relation(fields: [comarcaId], references: [id], onDelete: SetNull)
  morada    String?
  telefone  String?
  email     String?
  descricao String?
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  inqueritos Inquerito[]
  @@index([ativo, ordem])
  @@index([comarcaId])
}

model Seccao {
  id        String   @id @default(cuid())
  nome      String
  descricao String?
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  comarcaId String?
  comarca   Comarca? @relation(fields: [comarcaId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  inqueritos Inquerito[]
  @@index([ativo, ordem])
  @@index([comarcaId])
}


// Etiqueta (tag) pessoal — cada utilizador cria as suas, únicas dentro do seu
// perfil (@@unique [criadoPorId, nome]). Atribuível a vários inquéritos (m2m
// implícita) para categorização livre — ex.: "Prioritário", "Aguardando MP".
// Uma vez aplicada, a etiqueta "viaja" com o inquérito e fica visível a quem o
// vê, independentemente de quem a criou.
model Etiqueta {
  id          String   @id @default(cuid())
  nome        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  criadoPor   Utilizador @relation(fields: [criadoPorId], references: [id], onDelete: Cascade)
  criadoPorId String

  inqueritos Inquerito[]

  @@unique([criadoPorId, nome])
  @@index([criadoPorId])
}

model Atividade {
  id             String    @id @default(cuid())
  descricao      String
  observacoes    String?
  quantidade     Int?
  dataPrazo      DateTime?
  alertaDias1    Int?
  alertaDias2    Int?
  alerta1Enviado Boolean   @default(false)
  alerta2Enviado Boolean   @default(false)
  dataRealizacao DateTime  @default(now())
  // When set, the work this atividade represents is "done" — used both by
  // the dashboard counters (Aguarda Exames / Enviados) and the cron to stop
  // firing alerts. Independent of `dataPrazo`: an atividade without a prazo
  // can still be marked as completed (a closed event marker).
  concluidaEm    DateTime?
  createdAt      DateTime  @default(now())

  inquerito   Inquerito @relation(fields: [inqueritoid], references: [id], onDelete: Cascade)
  inqueritoid String

  realizadaPor Utilizador @relation(fields: [utilizadorId], references: [id])
  utilizadorId String

  controlo Controlo?

  @@index([inqueritoid])
  @@index([utilizadorId])
  @@index([inqueritoid, dataRealizacao])
  @@index([dataPrazo])
  @@index([concluidaEm])
}

// Controlos — recurring (or one-time) check-ins, optionally linked to an inquiry.
// periodoDias = null → one-time deadline; > 0 → repeats every N days.
model Controlo {
  id          String    @id @default(cuid())
  descricao   String
  observacoes String?
  dataInicio  DateTime
  periodoDias Int?
  alertaDias  Int       @default(3)
  concluidoEm DateTime?
  createdAt   DateTime  @default(now())

  inqueritoid String?
  inquerito   Inquerito?  @relation(fields: [inqueritoid], references: [id], onDelete: SetNull)

  atividadeId String?   @unique
  atividade   Atividade? @relation(fields: [atividadeId], references: [id], onDelete: SetNull)

  criadorId   String
  criador     Utilizador  @relation("ControloCriador", fields: [criadorId], references: [id])

  realizacoes ControloRealizacao[]

  @@index([inqueritoid])
  @@index([criadorId])
  @@index([dataInicio])
}

// Each numbered occurrence of a Controlo (1.º Controlo, 2.º Controlo, …).
model ControloRealizacao {
  id             String    @id @default(cuid())
  numero         Int
  dataEsperada   DateTime
  dataRealizacao DateTime?
  observacoes    String?
  alertaEnviado  Boolean   @default(false)
  createdAt      DateTime  @default(now())

  controlo    Controlo   @relation(fields: [controloId], references: [id], onDelete: Cascade)
  controloId  String

  realizadoPorId String?
  realizadoPor   Utilizador? @relation("ControloRealizacaoPor", fields: [realizadoPorId], references: [id], onDelete: SetNull)

  @@unique([controloId, numero])
  @@index([controloId])
  @@index([dataEsperada])
}

model Notificacao {
  id           String          @id @default(cuid())
  tipo         TipoNotificacao
  titulo       String
  mensagem     String
  lida         Boolean         @default(false)
  limpa        Boolean         @default(false)
  emailEnviado Boolean         @default(false)
  createdAt    DateTime        @default(now())

  utilizador   Utilizador @relation(fields: [utilizadorId], references: [id], onDelete: Cascade)
  utilizadorId String

  inquerito   Inquerito? @relation(fields: [inqueritoid], references: [id], onDelete: SetNull)
  inqueritoid String?

  @@index([utilizadorId, lida])
  @@index([utilizadorId, limpa])
  @@index([utilizadorId, createdAt])
  @@index([createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  acao         String
  entidade     String
  entidadeId   String
  utilizadorId String
  detalhes     Json?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([entidade, entidadeId])
  @@index([utilizadorId])
  @@index([createdAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String?
  userAgent String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ip, createdAt])
  @@index([createdAt])
}

model ConfiguracaoSistema {
  id                              String   @id @default("singleton")
  backupScheduleCron              String   @default("0 2 * * *")
  // Quando true, o middleware bloqueia utilizadores não-ADMINISTRACAO com 503.
  // Activado/desactivado pelo endpoint de restauro e disponível como toggle
  // manual em /configurações para janelas de manutenção planeadas.
  maintenanceMode                 Boolean  @default(false)
  // When false, the Ajudas Mensais module is hidden and all its API routes
  // return 503. Only ADMINISTRACAO can toggle this in Configurações → Sistema.
  moduloAjudasAtivo               Boolean  @default(true)
  // Comma-separated list of Role values that can access the Ajudas module when
  // it is active. ADMINISTRACAO always has access and is never stored here.
  moduloAjudasRoles               String   @default("INSPETOR,INSPETOR_CHEFE,COORDENADOR")
  // When false, the Férias module is hidden and all its API routes return 503.
  // Only ADMINISTRACAO can toggle this in Configurações → Sistema.
  moduloFeriasAtivo               Boolean  @default(true)
  // Comma-separated list of Role values that can access the Férias module when
  // it is active. ADMINISTRACAO always has access and is never stored here.
  moduloFeriasRoles               String   @default("INSPETOR,INSPETOR_CHEFE,COORDENADOR")
  // When false, users can no longer submit bug reports (the /reportar-bug page
  // and its POST route return "module disabled"). The ADMINISTRACAO management
  // page (/bugs) is always available so existing reports can still be analysed.
  moduloBugReportsAtivo           Boolean  @default(true)
  // Comma-separated list of Role values allowed to submit bug reports when the
  // module is active. ADMINISTRACAO always has access and is never stored here.
  moduloBugReportsRoles           String   @default("INSPETOR,INSPETOR_CHEFE,COORDENADOR")
  // When false, the Toolbox module (investigator utilities: IP lookup, email
  // header analysis, DNS, etc.) is hidden and its API routes return 503.
  moduloToolboxAtivo              Boolean  @default(true)
  // Comma-separated list of Role values allowed to use the Toolbox when the
  // module is active. ADMINISTRACAO always has access and is never stored here.
  moduloToolboxRoles              String   @default("INSPETOR,INSPETOR_CHEFE,COORDENADOR")
  // When false, the Anexos feature (documentos anexados a inquéritos) is hidden
  // on the inquiry detail page and its API routes return 503. Only ADMINISTRACAO
  // can toggle this in Configurações → Sistema.
  moduloAnexosAtivo               Boolean  @default(true)
  // Comma-separated list of Role values allowed to see/manage attachments when
  // the module is active. ADMINISTRACAO always has access and is never stored here.
  moduloAnexosRoles               String   @default("INSPETOR,INSPETOR_CHEFE,COORDENADOR")
  // Explicações por IA na Toolbox (LLM local via Ollama). Opt-in: o admin só
  // deve ativar depois de descarregar o modelo no container Ollama.
  toolboxIaAtivo                  Boolean  @default(false)
  toolboxIaModelo                 String   @default("qwen3:4b")
  // Idle timeout in minutes. 0 disables the feature.
  sessaoTimeoutMinutos            Int      @default(0)
  prazoAlertaDias                 Int      @default(7)
  // Segundo limiar (opcional, mais próximo do prazo) para um aviso "urgente"
  // de inquéritos: quando o prazo cai dentro deste nº de dias, escala também
  // ao Inspetor-Chefe da brigada. null = desligado.
  prazoAlertaDiasUrgente          Int?
  emailRemetenteNome              String   @default("GPI Sistema")
  emailRemetenteAddr              String   @default("noreply@gpi.pt")
  // Ligação ao servidor SMTP, configurável pelo ADMINISTRACAO em
  // /configurações → Sistema. Quando smtpHost está definido, sobrepõe-se às
  // variáveis de ambiente SMTP_*; caso contrário usa-se o fallback de env.
  // A palavra-passe é guardada cifrada (AES-256-GCM, ver src/lib/crypto-secrets.ts)
  // e nunca é devolvida em texto pela API.
  smtpHost                        String?
  smtpPort                        Int?
  smtpSecure                      Boolean  @default(false)
  smtpUser                        String?
  smtpPasswordEnc                 String?
  // Módulo de notificações por email. false = nenhum email é enviado pelo sistema,
  // independentemente das políticas por tipo. Útil durante fases de teste/integração.
  emailNotificacoesAtivo          Boolean  @default(true)
  // Default estado codigos applied to /inqueritos when the user has no explicit
  // filter set on the URL. Stored as codigos for stability across renames.
  inqueritoFiltroEstadosDefault   String[] @default([])
  // Cache da última verificação à GitHub Releases. Escrito pelo worker no
  // tick agendado e pelo endpoint POST /api/updates/check.
  latestVersionTag                String?
  latestVersionCheckedAt          DateTime?
  latestVersionUrl                String?
  latestVersionNotes              String?
  // Personalização (branding) — null em qualquer campo = usar o default
  // codificado em src/lib/brand-defaults.ts. Os ficheiros referenciados
  // (logos, favicon) vivem em BRANDING_DIR (bind mount ./branding).
  // brandUpdatedAt é usado como cache-busting `?v=<ts>` para os assets.
  appName                         String?
  appShortName                    String?
  appDescription                  String?
  manifestDescription             String?
  pdfFooterText                   String?
  appAuthor                       String?
  logoLightFilename               String?
  logoDarkFilename                String?
  faviconFilename                 String?
  logoHorizontalLightFilename     String?
  logoHorizontalDarkFilename      String?
  // Escala em % (10–200) e alinhamento (left|center|right) do logo horizontal na sidebar.
  logoHorizontalEscala            Int      @default(100)
  logoHorizontalAlinhamento       String   @default("center")
  brandUpdatedAt                  DateTime?
  updatedAt                       DateTime @updatedAt
}

// Cada tentativa de atualização da app deixa uma linha aqui. A FSM (campo
// `state`) é validada em escrita por src/lib/updates/state-machine.ts; este
// modelo é o ponto único de verdade observado pelo UI e pelo audit.
model AtualizacaoSistema {
  id              String   @id @default(cuid())
  // Idempotency key passada pelo cliente (header Idempotency-Key). Permite
  // que retries da request POST /api/updates/start não criem duplicados.
  requestId       String   @unique
  fromVersion     String
  toVersion       String
  fromCommitSha   String
  toCommitSha     String?
  // Nome do estado da FSM. Strings em vez de enum para evitar migrações
  // sempre que se adiciona um estado intermédio.
  state           String
  // Filename do gpi_prerestore_*.sql.gz criado antes do update, usado pelo
  // path de rollback para reverter a BD.
  preBackupFile   String?
  startedAt       DateTime @default(now())
  finishedAt      DateTime?
  errorMessage    String?
  rolledBack      Boolean  @default(false)
  iniciadoPorId   String
  iniciadoPor     Utilizador @relation(fields: [iniciadoPorId], references: [id])

  @@index([startedAt])
  @@index([state])
}

model AtividadePadrao {
  id                    String   @id @default(cuid())
  nome                  String   @unique
  descricao             String?
  ativa                 Boolean  @default(true)
  ordem                 Int      @default(0)
  temPrazo              Boolean  @default(false)
  temQuantidade         Boolean  @default(false)
  temControlo           Boolean  @default(false)
  // When false, activities of this type are excluded from analytical
  // aggregations (e.g. "Resumo por tipo" in the inquérito detail). The total
  // count of activities is unaffected.
  contaParaEstatistica  Boolean  @default(true)
  // Optional auto-transition: when an Atividade with this padrão's `nome` is
  // created, the parent inquérito is moved to this estado (subject to the
  // state machine). Null means no transition.
  transicaoEstado   EstadoInquerito? @relation(fields: [transicaoEstadoId], references: [id], onDelete: SetNull)
  transicaoEstadoId String?
  // Optional category for the dashboard counters. Values are an app-level
  // union ('AGUARDA_EXAMES' | 'ENVIADO'); kept as a nullable String so new
  // categories can be added without a Prisma migration.
  categoriaDashboard String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([transicaoEstadoId])
  @@index([categoriaDashboard])
}

enum AjudasPrevencao {
  NENHUMA
  PIQUETE
  PREVENCAO_PASSIVA
}

enum AjudasViatura {
  PROPRIA
  BRIGADA
}

model Viatura {
  id           String        @id @default(cuid())
  utilizadorId String
  utilizador   Utilizador    @relation(fields: [utilizadorId], references: [id], onDelete: Cascade)
  nome         String
  matricula    String?       @unique
  ativo        Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  linhas       AjudasLinha[]

  @@index([utilizadorId])
}

// Singleton config for Ajudas Mensais - managed by ADMINISTRACAO
model AjudasConfig {
  id                      String   @id @default("default")
  vencimentoBase          Float    @default(1974.41)
  vencimentoDN            Float    @default(7143.207)
  percentPiqueteSemana    Float    @default(0.083)
  percentPiqueteFds       Float    @default(0.105)
  percentPrevencaoPassiva Float    @default(0.4)
  senhaAlmoco             Float    @default(9.60)
  senhaJantar             Float    @default(8.23)
  senhaCeia               Float    @default(4.24)
  taxaIRS                 Float    @default(0.1116)
  taxaSS                  Float    @default(0.11)
  distanciaMinKmAjudas    Int      @default(35)
  updatedAt               DateTime @updatedAt
}

// Monthly record per inspector (auto-created on first access)
model AjudasRegisto {
  id           String        @id @default(cuid())
  utilizadorId String
  utilizador   Utilizador    @relation(fields: [utilizadorId], references: [id], onDelete: Cascade)
  ano          Int
  mes          Int           // 1-12
  linhas       AjudasLinha[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([utilizadorId, ano, mes])
  @@index([utilizadorId])
}

// Individual callout/activity entry
model AjudasLinha {
  id                   String          @id @default(cuid())
  registoId            String
  registo              AjudasRegisto   @relation(fields: [registoId], references: [id], onDelete: Cascade)
  nuipc                String?
  local                String?
  dataInicio           DateTime
  dataFim              DateTime
  prevencao            AjudasPrevencao @default(NENHUMA)
  // When true, this entry records only a prevencao/piquete fee (no overtime hours).
  // splitHours is skipped; only the prevencao period is counted.
  prevencaoOnly        Boolean         @default(false)
  ajudaCustoAlmoco     Int             @default(0)
  ajudaCustoJantar     Int             @default(0)
  ajudaCustoCeia       Int             @default(0)
  senhaAlmoco          Int             @default(0)
  senhaJantar          Int             @default(0)
  senhaCeia            Int             @default(0)
  viaturaId            String?
  viatura              Viatura?        @relation(fields: [viaturaId], references: [id], onDelete: SetNull)
  km                   Int             @default(0)
  observacoes          String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([registoId])
  @@index([viaturaId])
}

// Vacation / days-off marking by an inspector. View-only for the chefe (no
// approval flow). Dates are date-only (local midnight) and inclusive.
model Ausencia {
  id         String       @id @default(cuid())
  inspetorId String
  inspetor   Utilizador   @relation("AusenciasInspetor", fields: [inspetorId], references: [id], onDelete: Cascade)
  // Snapshot of inspetor.brigadaId at create time — keeps brigade queries fast
  // and stable even if the inspector later changes brigade.
  brigadaId  String?
  brigada    Brigada?     @relation(fields: [brigadaId], references: [id], onDelete: SetNull)
  tipo       TipoAusencia
  dataInicio DateTime
  dataFim    DateTime
  nota       String?
  deletedAt  DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([inspetorId])
  @@index([brigadaId])
  @@index([deletedAt])
  @@index([inspetorId, dataInicio])
}

model Sessao {
  id           String     @id @default(cuid())
  sessionToken String     @unique
  expires      DateTime

  utilizador   Utilizador @relation(fields: [utilizadorId], references: [id], onDelete: Cascade)
  utilizadorId String
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Token de reset de password. O `tokenHash` é o SHA-256 do valor enviado
// por email — o servidor nunca grava o token em claro, pelo que comprometer
// a BD não dá acesso retro-activo a contas via tokens activos.
//
// `usedAt` marca tokens já consumidos (single-use). `expiresAt` é o cutoff
// duro (1h após emissão por defeito). Tokens expirados ou usados continuam
// na tabela como audit trail até a limpeza periódica os apagar.
model PasswordResetToken {
  id           String    @id @default(cuid())
  tokenHash    String    @unique
  utilizadorId String
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())
  ip           String?
  userAgent    String?

  utilizador Utilizador @relation(fields: [utilizadorId], references: [id], onDelete: Cascade)

  @@index([utilizadorId])
  @@index([expiresAt])
}

// Política de envio por tipo de notificação. Uma row por TipoNotificacao
// (PK = tipo). Editável pelo ADMINISTRACAO em /configurações → Notificações.
//
// Semântica de envio:
//   - inAppEnabled: cria linha em Notificacao
//   - emailEnabled: chama sendMail() (continua a respeitar DISABLE_EMAIL global)
//   - ccRoles: utilizadores com estes roles recebem em adição ao destinatário
//     "natural" do contexto (inspetor do inquérito, criador da atividade, ...).
//     Lista vazia = só o destinatário natural; ['ADMINISTRACAO'] = todos os
//     admins activos também recebem.
//
// O seed cria a row faltante para cada valor do enum (idempotente). Se o
// enum ganhar um tipo novo, a próxima boot cria a row com defaults.
model NotificationPolicy {
  tipo         TipoNotificacao @id
  inAppEnabled Boolean         @default(true)
  emailEnabled Boolean         @default(true)
  ccRoles      Role[]          @default([])
  updatedAt    DateTime        @updatedAt
}

// Preferência de email por utilizador e por tipo de notificação. Permite a
// cada utilizador optar por NÃO receber emails de um dado tipo (o in-app
// mantém-se sempre, controlado pela NotificationPolicy global). A ausência de
// linha significa "ativo" (default on) — só guardamos opt-outs explícitos.
model NotificacaoPreferencia {
  utilizadorId String
  tipo         TipoNotificacao
  emailEnabled Boolean         @default(true)
  utilizador   Utilizador      @relation(fields: [utilizadorId], references: [id], onDelete: Cascade)

  @@id([utilizadorId, tipo])
}

// Relatório de bug submetido por um utilizador para análise do ADMINISTRACAO.
// Centralizado em /bugs (gestão admin); submetido em /reportar-bug. O módulo
// pode ser ligado/desligado em Configurações → Sistema.
model BugReport {
  id          String        @id @default(cuid())
  titulo      String
  descricao   String
  severidade  SeveridadeBug @default(MEDIA)
  estado      EstadoBug     @default(ABERTO)
  // Página/contexto onde o bug foi observado (path ou URL), opcional.
  pagina      String?
  // Nota interna do administrador ao triar/analisar o report.
  notaAdmin   String?
  criadoPor   Utilizador    @relation(fields: [criadoPorId], references: [id], onDelete: Cascade)
  criadoPorId String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([estado, createdAt])
  @@index([criadoPorId])
  @@index([createdAt])
}

enum PrioridadeTarefa {
  BAIXA
  NORMAL
  ALTA
}

model TarefaInquerito {
  id          String          @id @default(cuid())
  titulo      String
  descricao   String?
  prioridade  PrioridadeTarefa @default(NORMAL)
  concluida   Boolean         @default(false)
  concluidaEm DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt

  inquerito   Inquerito @relation(fields: [inqueritoId], references: [id], onDelete: Cascade)
  inqueritoId String

  autor   Utilizador @relation(fields: [autorId], references: [id])
  autorId String

  @@index([autorId])
  @@index([inqueritoId])
  @@index([autorId, concluida])
  @@index([autorId, prioridade])
}
