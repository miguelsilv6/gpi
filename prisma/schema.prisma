generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  INSPETOR
  INSPETOR_CHEFE
  COORDENADOR
  ESTATISTICA
  ADMINISTRACAO
}

enum TipoNotificacao {
  BACKUP_FALHOU
  PRAZO_APROXIMANDO
  PRAZO_ULTRAPASSADO
  ATIVIDADE_ADICIONADA
  INQUERITO_ATRIBUIDO
  INQUERITO_TRANSFERIDO
  ATIVIDADE_PRAZO_APROXIMANDO
  ATUALIZACAO_FALHOU
  ATUALIZACAO_CONCLUIDA
}

model Brigada {
  id          String   @id @default(cuid())
  nome        String   @unique
  descricao   String?
  ativa       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  utilizadores Utilizador[]
  inqueritos   Inquerito[]
}

model Utilizador {
  id           String   @id @default(cuid())
  nome         String
  email        String   @unique
  // Internal identification number (e.g. "número de LT"). Unique when set,
  // optional so legacy accounts and seed users don't have to backfill yet.
  lt           Int?     @unique
  telemovel    String?
  passwordHash String
  role         Role
  ativo        Boolean  @default(true)
  chefeSupremo Boolean  @default(false)
  tokenVersion Int      @default(0)
  lockedUntil  DateTime?
  failedLoginCount Int  @default(0)
  lastLoginAt  DateTime?
  lastLoginIp  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  brigada   Brigada? @relation(fields: [brigadaId], references: [id])
  brigadaId String?

  inqueritos           Inquerito[]   @relation("InspetorAtribuido")
  atividadesRealizadas Atividade[]
  notificacoes         Notificacao[]
  sessoes              Sessao[]
  passwordResetTokens  PasswordResetToken[]
  atualizacoesIniciadas AtualizacaoSistema[]
  etiquetas            Etiqueta[]

  @@index([brigadaId])
  @@index([role])
  @@index([brigadaId, role])
}

model Inquerito {
  id             String   @id @default(cuid())
  nuipc          String   @unique
  nai            String?  @unique
  // Free-text natureza, kept for transitional backfill. Once `crimeId` is
  // populated for every row (via scripts/migrate-natureza-to-crime.ts) and
  // the UI no longer reads from this field, a future migration drops it.
  natureza       String
  dataAbertura   DateTime
  dataPrazo      DateTime?
  dataConclusao  DateTime?
  notas          String?
  // Tribunal / Ministério Público — all optional, free-text.
  tribunal       String?
  procurador     String?
  oficialJustica String?
  voip           String?
  notasTribunal  String?
  // Denunciante (queixoso) — all optional. Tipo é 'SINGULAR' | 'COLETIVA'
  // ao nível da aplicação (nullable String para não exigir migração quando
  // surgirem novos tipos). NIF para singulares; NIPC para coletivas.
  denuncianteNome        String?
  denuncianteTipo        String?
  denuncianteNif         String?
  denuncianteMorada      String?
  denuncianteCodPostal   String?
  denuncianteLocalidade  String?
  denuncianteContacto    String?
  denuncianteEmail       String?
  denuncianteResponsavel String?
  denuncianteNotas       String?
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  estado   EstadoInquerito @relation(fields: [estadoId], references: [id])
  estadoId String

  brigada   Brigada? @relation(fields: [brigadaId], references: [id])
  brigadaId String?

  inspetor   Utilizador? @relation("InspetorAtribuido", fields: [inspetorId], references: [id])
  inspetorId String?

  crime    Crime?  @relation("CrimePrincipal", fields: [crimeId], references: [id])
  crimeId  String?
  // Crimes adicionais (m2m implícita). Não contam para estatísticas —
  // só o crime principal (crimeId) entra nos agrupamentos por crime,
  // garantindo que um inquérito nunca é contado mais de uma vez.
  crimesAssociados Crime[] @relation("CrimesAssociados")

  // Etiquetas (tags) pessoais aplicadas ao inquérito. Relação m2m implícita —
  // o join table `_EtiquetaToInquerito` é gerido pelo Prisma.
  etiquetas Etiqueta[]

  atividades   Atividade[]
  notificacoes Notificacao[]

  @@index([brigadaId])
  @@index([inspetorId])
  @@index([estadoId])
  @@index([crimeId])
  @@index([dataPrazo])
  @@index([nuipc])
  @@index([nai])
  @@index([updatedAt(sort: Desc)])
  @@index([brigadaId, updatedAt(sort: Desc)])
  @@index([inspetorId, updatedAt(sort: Desc)])
  @@index([deletedAt])
}

model EstadoInquerito {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nome      String
  descricao String?
  ordem     Int      @default(0)
  terminal  Boolean  @default(false)
  cor       String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inqueritos                   Inquerito[]
  atividadesPadraoQueTransitam AtividadePadrao[]

  @@index([ativo, ordem])
}

model Crime {
  id        String   @id @default(cuid())
  nome      String   @unique
  descricao String?
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inqueritos          Inquerito[] @relation("CrimePrincipal")
  inqueritoAssociados Inquerito[] @relation("CrimesAssociados")

  @@index([ativo, ordem])
}

// Etiqueta (tag) pessoal — cada utilizador cria as suas, únicas dentro do seu
// perfil (@@unique [criadoPorId, nome]). Atribuível a vários inquéritos (m2m
// implícita) para categorização livre — ex.: "Prioritário", "Aguardando MP".
// Uma vez aplicada, a etiqueta "viaja" com o inquérito e fica visível a quem o
// vê, independentemente de quem a criou.
model Etiqueta {
  id          String   @id @default(cuid())
  nome        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  criadoPor   Utilizador @relation(fields: [criadoPorId], references: [id], onDelete: Cascade)
  criadoPorId String

  inqueritos Inquerito[]

  @@unique([criadoPorId, nome])
  @@index([criadoPorId])
}

model Atividade {
  id             String    @id @default(cuid())
  descricao      String
  observacoes    String?
  quantidade     Int?
  dataPrazo      DateTime?
  alertaDias1    Int?
  alertaDias2    Int?
  alerta1Enviado Boolean   @default(false)
  alerta2Enviado Boolean   @default(false)
  dataRealizacao DateTime  @default(now())
  // When set, the work this atividade represents is "done" — used both by
  // the dashboard counters (Aguarda Exames / Enviados) and the cron to stop
  // firing alerts. Independent of `dataPrazo`: an atividade without a prazo
  // can still be marked as completed (a closed event marker).
  concluidaEm    DateTime?
  createdAt      DateTime  @default(now())

  inquerito   Inquerito @relation(fields: [inqueritoid], references: [id], onDelete: Cascade)
  inqueritoid String

  realizadaPor Utilizador @relation(fields: [utilizadorId], references: [id])
  utilizadorId String

  @@index([inqueritoid])
  @@index([utilizadorId])
  @@index([inqueritoid, dataRealizacao])
  @@index([dataPrazo])
  @@index([concluidaEm])
}

model Notificacao {
  id           String          @id @default(cuid())
  tipo         TipoNotificacao
  titulo       String
  mensagem     String
  lida         Boolean         @default(false)
  limpa        Boolean         @default(false)
  emailEnviado Boolean         @default(false)
  createdAt    DateTime        @default(now())

  utilizador   Utilizador @relation(fields: [utilizadorId], references: [id], onDelete: Cascade)
  utilizadorId String

  inquerito   Inquerito? @relation(fields: [inqueritoid], references: [id], onDelete: SetNull)
  inqueritoid String?

  @@index([utilizadorId, lida])
  @@index([utilizadorId, limpa])
  @@index([utilizadorId, createdAt])
  @@index([createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  acao         String
  entidade     String
  entidadeId   String
  utilizadorId String
  detalhes     Json?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([entidade, entidadeId])
  @@index([utilizadorId])
  @@index([createdAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String?
  userAgent String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ip, createdAt])
  @@index([createdAt])
}

model ConfiguracaoSistema {
  id                              String   @id @default("singleton")
  backupScheduleCron              String   @default("0 2 * * *")
  // Quando true, o middleware bloqueia utilizadores não-ADMINISTRACAO com 503.
  // Activado/desactivado pelo endpoint de restauro e disponível como toggle
  // manual em /configurações para janelas de manutenção planeadas.
  maintenanceMode                 Boolean  @default(false)
  prazoAlertaDias                 Int      @default(7)
  emailRemetenteNome              String   @default("GPI Sistema")
  emailRemetenteAddr              String   @default("noreply@gpi.pt")
  // Default estado codigos applied to /inqueritos when the user has no explicit
  // filter set on the URL. Stored as codigos for stability across renames.
  inqueritoFiltroEstadosDefault   String[] @default([])
  // Cache da última verificação à GitHub Releases. Escrito pelo worker no
  // tick agendado e pelo endpoint POST /api/updates/check.
  latestVersionTag                String?
  latestVersionCheckedAt          DateTime?
  latestVersionUrl                String?
  latestVersionNotes              String?
  // Personalização (branding) — null em qualquer campo = usar o default
  // codificado em src/lib/brand-defaults.ts. Os ficheiros referenciados
  // (logos, favicon) vivem em BRANDING_DIR (bind mount ./branding).
  // brandUpdatedAt é usado como cache-busting `?v=<ts>` para os assets.
  appName                         String?
  appShortName                    String?
  appDescription                  String?
  manifestDescription             String?
  pdfFooterText                   String?
  appAuthor                       String?
  logoLightFilename               String?
  logoDarkFilename                String?
  faviconFilename                 String?
  brandUpdatedAt                  DateTime?
  updatedAt                       DateTime @updatedAt
}

// Cada tentativa de atualização da app deixa uma linha aqui. A FSM (campo
// `state`) é validada em escrita por src/lib/updates/state-machine.ts; este
// modelo é o ponto único de verdade observado pelo UI e pelo audit.
model AtualizacaoSistema {
  id              String   @id @default(cuid())
  // Idempotency key passada pelo cliente (header Idempotency-Key). Permite
  // que retries da request POST /api/updates/start não criem duplicados.
  requestId       String   @unique
  fromVersion     String
  toVersion       String
  fromCommitSha   String
  toCommitSha     String?
  // Nome do estado da FSM. Strings em vez de enum para evitar migrações
  // sempre que se adiciona um estado intermédio.
  state           String
  // Filename do gpi_prerestore_*.sql.gz criado antes do update, usado pelo
  // path de rollback para reverter a BD.
  preBackupFile   String?
  startedAt       DateTime @default(now())
  finishedAt      DateTime?
  errorMessage    String?
  rolledBack      Boolean  @default(false)
  iniciadoPorId   String
  iniciadoPor     Utilizador @relation(fields: [iniciadoPorId], references: [id])

  @@index([startedAt])
  @@index([state])
}

model AtividadePadrao {
  id                    String   @id @default(cuid())
  nome                  String   @unique
  descricao             String?
  ativa                 Boolean  @default(true)
  ordem                 Int      @default(0)
  temPrazo              Boolean  @default(false)
  temQuantidade         Boolean  @default(false)
  // When false, activities of this type are excluded from analytical
  // aggregations (e.g. "Resumo por tipo" in the inquérito detail). The total
  // count of activities is unaffected.
  contaParaEstatistica  Boolean  @default(true)
  // Optional auto-transition: when an Atividade with this padrão's `nome` is
  // created, the parent inquérito is moved to this estado (subject to the
  // state machine). Null means no transition.
  transicaoEstado   EstadoInquerito? @relation(fields: [transicaoEstadoId], references: [id], onDelete: SetNull)
  transicaoEstadoId String?
  // Optional category for the dashboard counters. Values are an app-level
  // union ('AGUARDA_EXAMES' | 'ENVIADO'); kept as a nullable String so new
  // categories can be added without a Prisma migration.
  categoriaDashboard String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([transicaoEstadoId])
  @@index([categoriaDashboard])
}

model Sessao {
  id           String     @id @default(cuid())
  sessionToken String     @unique
  expires      DateTime

  utilizador   Utilizador @relation(fields: [utilizadorId], references: [id], onDelete: Cascade)
  utilizadorId String
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Token de reset de password. O `tokenHash` é o SHA-256 do valor enviado
// por email — o servidor nunca grava o token em claro, pelo que comprometer
// a BD não dá acesso retro-activo a contas via tokens activos.
//
// `usedAt` marca tokens já consumidos (single-use). `expiresAt` é o cutoff
// duro (1h após emissão por defeito). Tokens expirados ou usados continuam
// na tabela como audit trail até a limpeza periódica os apagar.
model PasswordResetToken {
  id           String    @id @default(cuid())
  tokenHash    String    @unique
  utilizadorId String
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())
  ip           String?
  userAgent    String?

  utilizador Utilizador @relation(fields: [utilizadorId], references: [id], onDelete: Cascade)

  @@index([utilizadorId])
  @@index([expiresAt])
}

// Política de envio por tipo de notificação. Uma row por TipoNotificacao
// (PK = tipo). Editável pelo ADMINISTRACAO em /configurações → Notificações.
//
// Semântica de envio:
//   - inAppEnabled: cria linha em Notificacao
//   - emailEnabled: chama sendMail() (continua a respeitar DISABLE_EMAIL global)
//   - ccRoles: utilizadores com estes roles recebem em adição ao destinatário
//     "natural" do contexto (inspetor do inquérito, criador da atividade, ...).
//     Lista vazia = só o destinatário natural; ['ADMINISTRACAO'] = todos os
//     admins activos também recebem.
//
// O seed cria a row faltante para cada valor do enum (idempotente). Se o
// enum ganhar um tipo novo, a próxima boot cria a row com defaults.
model NotificationPolicy {
  tipo         TipoNotificacao @id
  inAppEnabled Boolean         @default(true)
  emailEnabled Boolean         @default(true)
  ccRoles      Role[]          @default([])
  updatedAt    DateTime        @updatedAt
}
